{
  "manifest_version": 3,
  "name": "پرکردن فرم نظرسنجی آموزشیار",
  "version": "1.1",
  "description": "همه سوال‌های فرم ارزشیابی استاد را با یک گزینه پر یا پاک می‌کند.",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "پرکردن نظرسنجی",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
